# Copy this file to .env.local and fill in the values
# Supabase (PostgreSQL Database)
# Get from: https://supabase.com/dashboard/project/_/settings/database
DATABASE_URL=postgresql://postgres:fakepassword@db.fake.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:fakepassword@db.fake.supabase.co:5432/postgres

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-api...

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Upstash Redis (Rate Limiting)
UPSTASH_REDIS_REST_URL=https://fake-upstash.upstash.io
UPSTASH_REDIS_REST_TOKEN=faketoken123

# Extension Configuration
# Backend API URL for extension to call
VITE_API_URL=http://localhost:3000
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
# Set to 'true' to bypass credits during development (uses /api/agent/chat/dev)
VITE_USE_DEV_API=true

# Marketing Site
NEXT_PUBLIC_APP_URL=http://localhost:3001
