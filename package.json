{
  "name": "prophet",
  "version": "0.1.0",
  "description": "AI-powered Chrome extension SaaS with streaming chat, credits-based billing, and secure backend API",
  "license": "Apache-2.0",
  "author": "ThanosKa",
  "repository": {
    "type": "git",
    "url": "https://github.com/ThanosKa/prophet.git"
  },
  "bugs": "https://github.com/ThanosKa/prophet/issues",
  "homepage": "https://github.com/ThanosKa/prophet#readme",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:sidepanel": "pnpm -F @prophet/sidepanel dev",
    "dev:web": "pnpm -F @prophet/marketing dev",
    "build": "pnpm -r build",
    "build:sidepanel": "pnpm -F @prophet/sidepanel build",
    "build:web": "pnpm -F @prophet/marketing build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "type-check": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:run": "pnpm -r test:run",
    "test:coverage": "pnpm -r test:coverage",
    "test:agent": "./scripts/test-agent.sh",
    "db:generate": "pnpm -F @prophet/marketing db:generate",
    "db:migrate": "pnpm -F @prophet/marketing db:migrate",
    "db:studio": "pnpm -F @prophet/marketing db:studio",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.7",
      "@types/react-dom": "19.2.3"
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.27.0"
}
