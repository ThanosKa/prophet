# Chrome Extension Development (Manifest V3 + CRXJS)

## Manifest Configuration

### ✅ GOOD - Prophet Side Panel Setup

```typescript
// manifest.ts - Use defineManifest for type-safe config
import { defineManifest } from '@crxjs/vite-plugin'
import packageJson from './package.json'

const { version } = packageJson

// Parse semver for Chrome's 4-number format
const [major, minor, patch, label = '0'] = version
  .replace(/[^\d.-]+/g, '')
  .split(/[.-]/)

export default defineManifest(async (env) => ({
  manifest_version: 3,
  name: env.mode === 'staging' ? '[DEV] Prophet' : 'Prophet',
  version: `${major}.${minor}.${patch}.${label}`,
  version_name: version,
  description: 'AI-powered sidebar assistant',

  // Side panel configuration
  side_panel: {
    default_path: 'sidepanel.html',
  },

  // Required for side panel API
  permissions: ['sidePanel'],

  // Communicate with backend
  host_permissions: [
    'https://api.prophet.com/*', // Your backend
  ],

  // Extension icon
  action: {
    default_icon: {
      16: 'images/icon-16.png',
      48: 'images/icon-48.png',
      128: 'images/icon-128.png',
    },
  },
}))
```

### ❌ BAD - Incomplete or Insecure Setup

```typescript
// Missing permissions - side panel won't work
{
  side_panel: { default_path: 'sidepanel.html' }
  // Missing: "permissions": ["sidePanel"]
}

// Exposed sensitive data
{
  host_permissions: ['<all_urls>'], // Too broad!
  // Should specify exact backend domain
}

// Using Manifest V2 (outdated)
{
  manifest_version: 2, // Chrome deprecated this
}
```

