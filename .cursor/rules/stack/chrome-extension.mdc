## Side Panel Component

### ✅ GOOD - Secure API Communication

```typescript
// sidepanel/App.tsx - Side panel UI
'use client'

import { useState } from 'react'
import { ChatInput } from '@/components/ChatInput'
import { MessageList } from '@/components/MessageList'

export function App() {
  const [messages, setMessages] = useState<Message[]>([])
  const [isLoading, setIsLoading] = useState(false)

  const handleSendMessage = async (content: string) => {
    setIsLoading(true)

    try {
      // Send to YOUR backend (not content scripts, not side effects)
      const response = await fetch(
        `${import.meta.env.VITE_API_URL}/api/messages`,
        {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            // Auth token from Clerk (stored in extension storage)
            'Authorization': `Bearer ${await getAuthToken()}`,
          },
          body: JSON.stringify({ content }),
        }
      )

      if (!response.ok) {
        throw new Error(`API error: ${response.status}`)
      }

      // Handle streaming response
      const reader = response.body!.getReader()
      const decoder = new TextDecoder()
      let fullResponse = ''

      while (true) {
        const { done, value } = await reader.read()
        if (done) break

        fullResponse += decoder.decode(value, { stream: true })
        setMessages(prev => [
          ...prev.slice(0, -1),
          { role: 'assistant', content: fullResponse },
        ])
      }
    } catch (error) {
      setMessages(prev => [
        ...prev,
        {
          role: 'assistant',
          content: `Error: ${error instanceof Error ? error.message : 'Unknown error'}`,
        },
      ])
    } finally {
      setIsLoading(false)
    }
  }

  return (
    <div className="flex flex-col h-full">
      <MessageList messages={messages} isLoading={isLoading} />
      <ChatInput onSend={handleSendMessage} disabled={isLoading} />
    </div>
  )
}

async function getAuthToken(): Promise<string> {
  // Retrieve token from storage (set during authentication)
  const result = await chrome.storage.local.get('authToken')
  return result.authToken || ''
}
```

### ❌ BAD - Insecure Patterns

```typescript
// ❌ Don't send API key from extension
const apiKey = process.env.REACT_APP_ANTHROPIC_KEY // EXPOSED!
fetch('https://api.anthropic.com/...', {
  headers: { 'Authorization': `Bearer ${apiKey}` }
})

// ❌ Don't use content scripts for sensitive API calls
// Content scripts can be tampered with

// ❌ Don't hardcode backend URL
const API = 'https://hardcoded-url.com' // Can't change without rebuild
```

