# Clerk Authentication (Chrome Extension)
# Use pk_test_... for development, pk_live_... for production
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Backend API URL
# Development: http://localhost:3000
# Production: https://prophetchrome.com
VITE_API_URL=http://localhost:3000

# Clerk Sync Host (for Chrome extension session sync)
# Development: leave empty (uses VITE_API_URL)
# Production: https://clerk.yourdomain.com (Clerk Frontend API domain from Clerk Dashboard → Domains)
VITE_CLERK_SYNC_HOST=

# Development Modes (set to false for production)
# true = uses /api/agent/chat/dev (real API, no credit deduction)
# mock = uses mock responses (no API calls, instant UI/UX testing)
# false = production mode (real API with credit deduction)
VITE_USE_DEV_API=mock

# Chrome Extension ID (Found in chrome://extensions after loading unpacked)
# For production, use the Chrome Web Store assigned ID
VITE_EXTENSION_ID=your-extension-id