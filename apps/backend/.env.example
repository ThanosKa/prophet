# Backend API Environment Variables
# Copy this file to .env.local and fill in the values from root/.env.local

# Database (from root)
# Get from: https://supabase.com/dashboard/project/_/settings/database
DATABASE_URL=postgresql://postgres:fakepassword@db.fake.supabase.co:5432/postgres

# Anthropic API (from root - server-side only)
ANTHROPIC_API_KEY=sk-ant-api...

# Clerk Authentication (shared with root)
# Get from: https://dashboard.clerk.com/last-active?path=api-keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Upstash Redis (from root - rate limiting)
UPSTASH_REDIS_REST_URL=https://fake-upstash.upstash.io
UPSTASH_REDIS_REST_TOKEN=faketoken123

# Stripe (for payments and subscriptions)
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App URL (for Stripe redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3001
