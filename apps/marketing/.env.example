# Marketing + Backend API Environment Variables
# Copy this file to .env.local and fill in the values

# ==========================================
# Database
# ==========================================
# Get from: https://supabase.com/dashboard/project/_/settings/database
DATABASE_URL=postgresql://postgres:fakepassword@db.fake.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:fakepassword@db.fake.supabase.co:5432/postgres

# ==========================================
# Anthropic API (server-side only)
# ==========================================
ANTHROPIC_API_KEY=sk-ant-api...

# ==========================================
# Clerk Authentication
# ==========================================
# Get from: https://dashboard.clerk.com/last-active?path=api-keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# ==========================================
# Upstash Redis (rate limiting)
# ==========================================
UPSTASH_REDIS_REST_URL=https://fake-upstash.upstash.io
UPSTASH_REDIS_REST_TOKEN=faketoken123

# ==========================================
# Stripe (payments and subscriptions)
# ==========================================
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ==========================================
# App Configuration
# ==========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk Pages
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/auth-success
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/auth-success
