# Marketing App Environment Variables
# Copy this file to .env.local and fill in the values from root/.env.local

# Clerk Authentication (shared with root)
# Get from: https://dashboard.clerk.com/last-active?path=api-keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Clerk Pages
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/auth-success
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/auth-success
